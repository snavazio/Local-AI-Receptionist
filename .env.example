# ── Server ────────────────────────────────────────────────────────────────────
# Host/port the WebSocket server binds to.
# Twilio / FreeSWITCH / any SIP bridge should point here.
WS_HOST=0.0.0.0
WS_PORT=8765

# ── LLM (Ollama) ──────────────────────────────────────────────────────────────
# Ollama OpenAI-compatible endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1
# Model must be pulled first: `ollama pull qwen2.5:14b`
LLM_MODEL=qwen2.5:14b

# ── STT (faster-whisper) ──────────────────────────────────────────────────────
# Model name or HuggingFace repo. distil-large-v3 is the recommended default.
WHISPER_MODEL=distil-large-v3
# Device: "cuda" recommended on GPU machine, "cpu" as fallback.
WHISPER_DEVICE=cuda
# Compute type: "float16" for CUDA, "int8" for CPU.
WHISPER_COMPUTE_TYPE=float16

# ── TTS (Piper) ───────────────────────────────────────────────────────────────
# Voice model identifier — model files are downloaded to PIPER_DOWNLOAD_DIR.
PIPER_VOICE=en_US-lessac-medium
# Directory where Piper voice model files (.onnx / .onnx.json) are stored.
PIPER_DOWNLOAD_DIR=./voice_models

# ── Dental office ─────────────────────────────────────────────────────────────
# Phone number read aloud when the bot escalates a dental emergency.
EMERGENCY_LINE=5-5-5-9-1-1

# ── Idle / session limits ─────────────────────────────────────────────────────
# Seconds of silence before the pipeline task is auto-cancelled.
IDLE_TIMEOUT_SECS=120
